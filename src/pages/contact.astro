---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';

const description =
  'Get in touch with Alexandru Badiu. Best for slow questions, engineering chat, mentoring, and hiring conversations.';
const formAction = `https://formspree.io/f/${site.formspreeId}`;

const topics = [
  { id: 'hello', label: 'Just saying hi', active: true },
  { id: 'hiring', label: 'Hiring' },
  { id: 'engineering', label: 'Engineering' },
  { id: 'mentoring', label: 'Mentoring' },
  { id: 'speaking', label: 'Speaking' },
  { id: 'music', label: 'Music' },
];
---

<Base title="Contact · Alexandru Badiu" description={description} active="/contact">
  <header class="page-head enter">
    <div class="eyebrow">Contact</div>
    <h1>Drop a line.</h1>
    <p class="blurb">I read everything; I reply to most. Best for slow questions, engineering chat, mentoring, or hiring conversations. For anything urgent, LinkedIn is faster.</p>
  </header>

  <form class="cform enter" id="cform" method="POST" action={formAction} novalidate style="margin-top:44px;">
    <input type="hidden" name="_subject" value="New message from alexandrubadiu.ro" />
    <input type="hidden" name="topic" id="topic-field" value="hello" />
    <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;" aria-hidden="true" />

    <div class="cfield cfield-topic">
      <label>What's this about<span class="req">*</span></label>
      <div class="topics" id="topics" role="radiogroup">
        {topics.map((t) => (
          <button type="button" class:list={['topic-btn', { active: t.active }]} data-topic={t.id}>{t.label}</button>
        ))}
      </div>
    </div>

    <div class="cfield" id="f-name">
      <label for="name">Your name<span class="req">*</span></label>
      <input type="text" id="name" name="name" autocomplete="name" placeholder="What should I call you?" />
      <span class="err-msg">A name helps, even a first name.</span>
    </div>

    <div class="cfield" id="f-email">
      <label for="email">Email<span class="req">*</span></label>
      <input type="email" id="email" name="email" autocomplete="email" placeholder="so I can reply" />
      <span class="err-msg">That doesn't look like an email.</span>
    </div>

    <div class="cfield" id="f-message">
      <label for="message">Message<span class="req">*</span></label>
      <textarea id="message" name="message" rows="6" placeholder="No need to be polished. Half-formed is fine; I'll ask follow-ups."></textarea>
      <div class="char-count" id="char-count">0 / 2000</div>
      <span class="err-msg">Give me a sentence or two to work with.</span>
    </div>

    <div class="csubmit">
      <span class="priv">Your email stays with me. No list, no auto-replies, no third party beyond the form host.</span>
      <button type="submit" class="btn-send" id="send-btn">
        <span class="spinner"></span>
        <span class="label">SEND</span>
        <span class="arrow">→</span>
      </button>
    </div>
    <span class="err-msg" id="form-error" style="display:none;">Something went wrong sending that. Try again, or reach me on LinkedIn below.</span>
  </form>

  <div class="csuccess" id="csuccess" hidden>
    <div class="check">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
    </div>
    <h3 id="success-title">Got it. Thanks for writing.</h3>
    <p id="success-body">I'll get back to you within a week, usually sooner. If you don't hear back in two, assume the message slipped through and try again.</p>
    <a href="/" class="back-link">← Back to home</a>
  </div>

  <div class="calt">
    <div class="alt">
      <span class="alt-label">If forms aren't your thing</span>
      <a href={site.socials.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      <span class="alt-note">Faster for time-sensitive things and hiring.</span>
    </div>
    <div class="alt">
      <span class="alt-label">For code</span>
      <a href={site.socials.github} target="_blank" rel="noreferrer">GitHub @voidberg</a>
      <span class="alt-note">Open an issue, or say hello if our repos overlap.</span>
    </div>
  </div>

  <script slot="scripts">
    (function () {
      const topicsRoot = document.getElementById("topics");
      const topicField = document.getElementById("topic-field");
      let topic = "hello";
      topicsRoot.addEventListener("click", (e) => {
        const btn = e.target.closest(".topic-btn");
        if (!btn) return;
        topic = btn.dataset.topic;
        topicField.value = topic;
        topicsRoot.querySelectorAll(".topic-btn").forEach((b) => b.classList.toggle("active", b === btn));
      });

      const msg = document.getElementById("message");
      const cc = document.getElementById("char-count");
      const MAX = 2000;
      msg.addEventListener("input", () => {
        const len = msg.value.length;
        cc.textContent = `${len} / ${MAX}`;
        cc.classList.toggle("warn", len > MAX);
      });

      function clearError(id) { document.getElementById(id).classList.remove("error"); }
      function setError(id) { document.getElementById(id).classList.add("error"); }
      ["f-name", "f-email", "f-message"].forEach((id) => {
        const input = document.querySelector(`#${id} input, #${id} textarea`);
        if (input) input.addEventListener("input", () => clearError(id));
      });
      function validEmail(s) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(s); }

      const form = document.getElementById("cform");
      const sendBtn = document.getElementById("send-btn");
      const success = document.getElementById("csuccess");
      const formError = document.getElementById("form-error");

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        formError.style.display = "none";

        const name = document.getElementById("name").value.trim();
        const email = document.getElementById("email").value.trim();
        const message = document.getElementById("message").value.trim();

        let ok = true;
        if (!name) { setError("f-name"); ok = false; }
        if (!validEmail(email)) { setError("f-email"); ok = false; }
        if (message.length < 4) { setError("f-message"); ok = false; }
        if (message.length > MAX) { setError("f-message"); ok = false; }
        if (!ok) return;

        sendBtn.classList.add("loading");
        sendBtn.disabled = true;

        try {
          const res = await fetch(form.action, {
            method: "POST",
            headers: { "Accept": "application/json" },
            body: new FormData(form),
          });
          if (!res.ok) throw new Error("Bad response");

          const titleByTopic = {
            hello: "Got it. Thanks for writing.",
            hiring: "Got it. Let's talk.",
            engineering: "Got it, engineering question received.",
            mentoring: "Got it. I'll have a think.",
            speaking: "Thanks, I'll consider it.",
            music: "Music notes, my favourite.",
          };
          document.getElementById("success-title").textContent = titleByTopic[topic] || titleByTopic.hello;

          form.style.display = "none";
          success.hidden = false;
          window.scrollTo({ top: 0, behavior: "smooth" });
        } catch (err) {
          sendBtn.classList.remove("loading");
          sendBtn.disabled = false;
          formError.style.display = "block";
        }
      });
    })();
  </script>
</Base>
