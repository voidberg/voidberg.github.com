---
import Base from "../layouts/Base.astro";
import { featuredProjects, projectSlug } from "../data/projects";
import { now, nowUpdated } from "../data/now";
import { Content as Bio } from "../prose/bio.md";

const description =
    "Alexandru Badiu, engineering leader in London. Twenty years building software, the last stretch leading teams across five countries. Currently looking for what's next.";
---

<Base
    title="Alexandru Badiu · LOADING…"
    description={description}
    bodyClass=""
    showControls={true}
    backHref="#page"
    backLabel="Back to top ↑"
>
    <link rel="stylesheet" href="/landing.css" slot="head" />

    <!-- ===== LOADER ===== -->
    <div id="loader" aria-hidden="true" slot="preloader">
        <div class="load-stripes" id="stripes"></div>
        <!-- The three lines reveal in order, the way they arrive on a real
             Spectrum: the typed command, the prompt to start the tape, then the
             header the machine finds on it. -->
        <div class="load-panel" id="loadlines">
            <div class="load-line" hidden>
                LOAD <span class="nm">"alex.badiu"</span>
            </div>
            <div class="load-status" hidden>
                Start tape, then press any key.
            </div>
            <div class="load-status" hidden>
                Program: <span class="nm">alex.badiu</span>
            </div>
        </div>
    </div>

    <!-- HERO -->
    <header class="hero">
        <div class="avatar enter">
            <img
                src="/img/hero-photo.png"
                width="630"
                height="378"
                alt="Alexandru Badiu beside a rooster in a Faroese village, red and white houses on the hill behind"
            />
            <span class="tag">SCREEN$</span>
        </div>
        <div class="hero-id">
            <div class="eyebrow enter">Me, in 30 seconds</div>
            <h1 class="enter">Alexandru Badiu</h1>
            <div class="subline enter mono">
                <span>Engineer</span><span class="sep">▚</span><span
                    >London</span
                ><span class="sep">▚</span><span>Open to what's next</span>
            </div>
        </div>
    </header>
    <div class="lede-body enter">
        <Bio />
    </div>

    <!-- NOW -->
    <section class="enter" style="margin-top: 42px;">
        <div class="slabel">
            <span class="k">NOW</span><h2>What I'm up to</h2><span class="line"
            ></span><span class="see-all">{nowUpdated}</span>
        </div>
        <div class="now-list">
            {
                now.map((item) => (
                    <div class="now-item">
                        <span class="nk">{item.label}</span>
                        <p set:html={item.body} />
                    </div>
                ))
            }
        </div>
    </section>

    <!-- PROJECTS -->
    <section class="enter" style="margin-top: 42px;">
        <div class="slabel">
            <span class="k">PROJ</span><h2>A few things I've built</h2><span
                class="line"></span><a class="see-all" href="/projects"
                >See all →</a
            >
        </div>
        <div class="proj-grid">
            {
                featuredProjects.map((p) => (
                    <a class="proj" href={`/projects#${projectSlug(p)}`}>
                        {p.image ? (
                            <img
                                class="pimg"
                                src={`/projects/${p.image}-featured.png`}
                                width="670"
                                height="128"
                                alt=""
                            />
                        ) : (
                            <canvas
                                class="px"
                                width="120"
                                height="64"
                                data-seed={p.seed}
                            />
                        )}
                        <div class="pname">{p.name}</div>
                        <div class="pdesc">{p.short ?? p.desc}</div>
                        <div class="ptag">{p.tag}</div>
                    </a>
                ))
            }
        </div>
    </section>

    <script slot="scripts">
        (function () {
            /* ---------- tiny bleep (WebAudio) ---------- */
            var AC = null,
                soundOn = false;
            function ctx() {
                if (!AC) {
                    try {
                        AC = new (
                            window.AudioContext || window.webkitAudioContext
                        )();
                    } catch (e) {}
                }
                // Browsers start the context suspended until a user gesture; resume it.
                if (AC && AC.state === "suspended") {
                    AC.resume();
                }
                return AC;
            }
            function bleep(freq, dur) {
                if (!soundOn) return;
                var c = ctx();
                if (!c) return;
                var o = c.createOscillator(),
                    g = c.createGain();
                o.type = "square";
                o.frequency.value = freq || 880;
                g.gain.value = 0.14;
                o.connect(g);
                g.connect(c.destination);
                var t = c.currentTime;
                o.start(t);
                g.gain.setValueAtTime(0.14, t);
                g.gain.exponentialRampToValueAtTime(0.0001, t + (dur || 0.06));
                o.stop(t + (dur || 0.06));
            }

            /* ---------- project thumbs ---------- */
            function paintProj(cv, seed) {
                var w = cv.width,
                    h = cv.height,
                    g = cv.getContext("2d");
                var pal = [
                    "#000",
                    "#22227a",
                    "#7a227a",
                    "#227a7a",
                    "#227a22",
                    "#7a6e22",
                ];
                var s = seed || 1;
                for (var y = 0; y < h; y += 4)
                    for (var x = 0; x < w; x += 4) {
                        s = (s * 1103515245 + 12345) & 0x7fffffff;
                        var r = (s >> 16) & 0xff;
                        g.fillStyle =
                            r < 150
                                ? pal[0]
                                : pal[
                                      1 + ((x + y + (r & 7)) % (pal.length - 1))
                                  ];
                        g.fillRect(x, y, 4, 4);
                    }
            }
            document.querySelectorAll(".proj .px").forEach(function (c) {
                paintProj(c, parseInt(c.dataset.seed, 10));
            });

            /* ---------- loader (authentic tape load: border bands + header message) ---------- */
            var loader = document.getElementById("loader");
            var stripes = document.getElementById("stripes");
            var lines = document.getElementById("loadlines").children;
            var timers = [];
            function clearTimers() {
                timers.forEach(clearTimeout);
                timers = [];
            }
            var SEEN_KEY = "ab_tape_loaded";
            /* The tab title follows the tape: it loads, then reports back the way a
           Spectrum does when a program finishes without error. */
            var TITLE_LOADING = document.title;
            var TITLE_LOADED = "Alexandru Badiu · 0 OK, 0:1";
            function runLoader() {
                clearTimers();
                document.title = TITLE_LOADING;
                loader.classList.remove("done", "hidden");
                stripes.classList.remove("data");
                document.body.classList.remove("revealed");
                for (var i = 0; i < lines.length; i++) lines[i].hidden = true;
                lines[0].hidden = false;
                bleep(1200, 0.12);
                /* The prompt to start the tape, then the pilot tone gives way to the
           data stream and the header appears. No bar, no byte counter. */
                timers.push(
                    setTimeout(function () {
                        lines[1].hidden = false;
                    }, 500),
                );
                timers.push(
                    setTimeout(function () {
                        stripes.classList.add("data");
                        lines[2].hidden = false;
                    }, 1400),
                );
                /* Load completes: remember it, reveal the page, then hide the loader. */
                timers.push(
                    setTimeout(function () {
                        bleep(1760, 0.1);
                        try {
                            localStorage.setItem(SEEN_KEY, "1");
                        } catch (e) {}
                        loader.classList.add("done");
                        document.body.classList.add("revealed");
                        document.title = TITLE_LOADED;
                        timers.push(
                            setTimeout(function () {
                                loader.classList.add("hidden");
                            }, 400),
                        );
                    }, 2600),
                );
            }
            var seen = false;
            try {
                seen = localStorage.getItem(SEEN_KEY) === "1";
            } catch (e) {}
            if (seen) {
                loader.classList.add("done", "hidden");
                document.body.classList.add("revealed");
                document.title = TITLE_LOADED;
            } else {
                runLoader();
            }

            /* ---------- controls ---------- */
            var sbtn = document.getElementById("sound-btn");
            sbtn.addEventListener("click", function () {
                soundOn = !soundOn;
                ctx();
                sbtn.classList.toggle("on", soundOn);
                sbtn.title = soundOn
                    ? "Sound on, click to mute"
                    : "Toggle bleeps";
                if (soundOn) bleep(988, 0.06);
            });
            document
                .getElementById("replay-btn")
                .addEventListener("click", function () {
                    bleep(660, 0.05);
                    runLoader();
                });
            document.querySelectorAll(".proj").forEach(function (el) {
                el.addEventListener("mouseenter", function () {
                    bleep(1320, 0.03);
                });
            });
        })();
    </script>
</Base>
