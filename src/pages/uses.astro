---
import Base from '../layouts/Base.astro';
import { uses } from '../data/uses';

const description = 'The boring honest list of tools and tech Alexandru Badiu actually reaches for.';
---

<Base title="Uses · Alexandru Badiu" description={description} active="/uses">
  <header class="page-head enter">
    <div class="eyebrow">Uses · the boring honest list</div>
    <h1>What I work with.</h1>
    <p class="blurb">The tools and tech I actually reach for. Only things I've genuinely used. If it isn't here, I either don't use it or haven't trusted it long enough to admit to.</p>
  </header>

  {uses.map((group, i) => (
    <section class="uses-group enter" style={i === 0 ? 'margin-top:48px;' : undefined}>
      <h3>{group.group}</h3>
      <ul class="uses-list">
        {group.items.map((item) => (
          <li>
            <span class="u-name">{item.name}</span>
            <span class="u-note">{item.note}{item.since && <span class="since">since {item.since}</span>}</span>
          </li>
        ))}
      </ul>
    </section>
  ))}

  <div class="now-foot">
    No hardware or desk list here yet. When I've decided what's actually worth admitting to, it goes on.
    <br />
    Inspired by the <a href="https://uses.tech" target="_blank" rel="noreferrer">/uses</a> directory, a collection of "what I use" pages started by Wes Bos.
  </div>
</Base>
