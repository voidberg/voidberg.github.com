---
import Base from "../layouts/Base.astro";
import { getCollection, render } from "astro:content";

const description =
    "Things Alexandru Badiu has built: Spotlight, Watch, small open-source tools used in surprising places, afternoon hacks, and chiptunes.";

const projects = (await getCollection("projects")).sort(
    (a, b) => a.data.order - b.data.order,
);
// Render each project's Markdown description to a component up front.
const entries = await Promise.all(
    projects.map(async (p) => ({ ...p, Desc: (await render(p)).Content })),
);
---

<Base
    title="Projects · Alexandru Badiu"
    description={description}
    active="/projects"
>
    <header class="page-head enter">
        <div class="eyebrow">Projects · the directory</div>
        <h1>Things I've built.</h1>
        <p class="blurb">
            Some things built carefully over years, some in an afternoon. Work
            I'm proud of, open source, and a few things that got out of hand.
        </p>
    </header>

    <section class="enter" style="margin-top:44px;">
        <div class="project-list">
            {
                entries.map((p, i) => (
                    <article class="project-entry" id={p.id}>
                        <div class="pe-thumb">
                            {p.data.image ? (
                                <img
                                    class="pe-thumb-img"
                                    src={`/projects/${p.data.image}-card.png`}
                                    width="340"
                                    height="228"
                                    alt=""
                                />
                            ) : (
                                <canvas
                                    width="170"
                                    height="114"
                                    data-seed={p.data.seed}
                                />
                            )}
                            <div class="pe-idx">
                                PROG {String(i + 1).padStart(2, "0")}
                            </div>
                        </div>
                        <div class="pe-body">
                            <div class="pe-head">
                                <h2 class="pe-name">{p.data.name}</h2>
                                <span class:list={["pe-status", p.data.status]}>
                                    {p.data.statusLabel}
                                </span>
                            </div>
                            <div class="pe-meta">
                                {p.data.meta.map((m, j) => (
                                    <>
                                        {j > 0 && <span class="dot">·</span>}
                                        <span>{m}</span>
                                    </>
                                ))}
                            </div>
                            <div class="pe-desc">
                                <p.Desc />
                            </div>
                            <div class="pe-stack">
                                {p.data.stack.map((s) => (
                                    <span>{s}</span>
                                ))}
                            </div>
                            {p.data.links && p.data.links.length > 0 && (
                                <div class="pe-links">
                                    {p.data.links.map((l) => (
                                        <a
                                            href={l.href}
                                            target="_blank"
                                            rel="noreferrer"
                                        >
                                            {l.label}
                                        </a>
                                    ))}
                                </div>
                            )}
                        </div>
                    </article>
                ))
            }
        </div>
    </section>

    <script slot="scripts">
        (function () {
            var pal = [
                "#000",
                "#22227a",
                "#7a227a",
                "#227a7a",
                "#227a22",
                "#7a6e22",
            ];
            document
                .querySelectorAll(".pe-thumb canvas")
                .forEach(function (cv) {
                    var w = cv.width,
                        h = cv.height,
                        g = cv.getContext("2d");
                    var s = parseInt(cv.dataset.seed, 10) || 1;
                    for (var y = 0; y < h; y += 5)
                        for (var x = 0; x < w; x += 5) {
                            s = (s * 1103515245 + 12345) & 0x7fffffff;
                            var r = (s >> 16) & 0xff;
                            g.fillStyle =
                                r < 150
                                    ? pal[0]
                                    : pal[
                                          1 +
                                              ((x + y + (r & 7)) %
                                                  (pal.length - 1))
                                      ];
                            g.fillRect(x, y, 5, 5);
                        }
                });
        })();
    </script>
</Base>
